# Copy to .env for local development (never commit .env)

NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# MongoDB Atlas connection string (required in production)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/bakbakbox_news

# Frontend URL(s) — comma-separated for multiple origins (Vercel + preview)
CLIENT_URL=https://your-app.vercel.app

JWT_SECRET=change_me_to_a_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# Cloudinary (admin image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=bakbakbox-news

# Live RSS sync
NEWS_SYNC_ENABLED=true
NEWS_SYNC_INTERVAL_MS=30000
NEWS_SYNC_MAX_AGE_HOURS=48

# Optional: create first superadmin on startup if DB is empty
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123456
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_WINDOW_MS=900000
SHUTDOWN_TIMEOUT_MS=10000
